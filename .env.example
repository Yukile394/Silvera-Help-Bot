# Discord Bot Token (Discord Developer Portal'dan alın)
DISCORD_TOKEN=your_bot_token_here

# Bot'un Application ID'si
CLIENT_ID=your_client_id_here

# Slash komutları belirli bir sunucuya deploy etmek için (opsiyonel, geliştirme için)
GUILD_ID=your_guild_id_here

# Bot'un durumu: online | idle | dnd | invisible
BOT_STATUS=online

# Bot'un aktivite mesajı
BOT_ACTIVITY=Silvera Help | /yardim

# Log kanalı ID'si (opsiyonel)
LOG_CHANNEL_ID=your_log_channel_id_here
